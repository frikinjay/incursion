{
  "name": "incursion",
  "version": "1.0.2",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder -l",
    "build:win-linux": "electron-builder -w -l",
    "build:win-linux-mac": "electron-builder -w -l -m"
  },
  "build": {
    "appId": "com.incursion.modmanager",
    "productName": "Incursion",
    "icon": "icon.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game",
      "syncDesktopName": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
